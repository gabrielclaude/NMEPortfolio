generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum TherapeuticArea {
  ONCOLOGY
  CARDIOVASCULAR
  NEUROLOGY
  IMMUNOLOGY
  INFECTIOUS_DISEASE
  METABOLIC
  RESPIRATORY
  RARE_DISEASE
  OPHTHALMOLOGY
  DERMATOLOGY
}

enum MoleculeType {
  SMALL_MOLECULE
  BIOLOGIC
  ANTIBODY
  PEPTIDE
  OLIGONUCLEOTIDE
  GENE_THERAPY
  CELL_THERAPY
}

enum NMEStatus {
  PRECLINICAL
  IND_FILED
  PHASE_1
  PHASE_2
  PHASE_3
  PHASE_4
  NDA_FILED
  APPROVED
  DISCONTINUED
  ON_HOLD
}

enum TrialPhase {
  PHASE_1
  PHASE_1B
  PHASE_2
  PHASE_2B
  PHASE_3
  PHASE_3B
  PHASE_4
  EXPANDED_ACCESS
}

enum TrialStatus {
  PLANNING
  RECRUITING
  ACTIVE
  ENROLLMENT_COMPLETE
  COMPLETED
  SUSPENDED
  TERMINATED
  WITHDRAWN
}

enum StaffRole {
  PRINCIPAL_SCIENTIST
  MEDICAL_MONITOR
  RESEARCH_ASSOCIATE
  CLINICAL_OPERATIONS_MANAGER
  DATA_MANAGER
  BIOSTATISTICIAN
  REGULATORY_AFFAIRS
  PROJECT_MANAGER
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  AT_RISK
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
  SKIPPED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model NME {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  genericName       String?
  therapeuticArea   TherapeuticArea
  moleculeType      MoleculeType
  status            NMEStatus
  targetIndication  String
  mechanismOfAction String?
  originatorCompany String?
  patentExpiry      DateTime?
  indFilingDate     DateTime?
  discoveryDate     DateTime
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  trials            ClinicalTrial[]

  @@index([therapeuticArea])
  @@index([status])
}

model ClinicalTrial {
  id                String      @id @default(cuid())
  nctNumber         String      @unique
  title             String
  phase             TrialPhase
  status            TrialStatus
  sponsorProtocolId String?
  primaryEndpoint   String?
  studyDesign       String?
  targetEnrollment  Int
  actualEnrollment  Int         @default(0)
  plannedStartDate  DateTime
  plannedEndDate    DateTime
  actualStartDate   DateTime?
  actualEndDate     DateTime?
  sites             Int         @default(1)
  countries         String[]
  budget            Decimal?    @db.Decimal(14, 2)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  nmeId             String
  nme               NME         @relation(fields: [nmeId], references: [id])

  leadStaffId       String?
  leadStaff         Staff?      @relation("TrialLead", fields: [leadStaffId], references: [id])

  projects          Project[]
  staffAssignments  TrialStaffAssignment[]

  @@index([nmeId])
  @@index([status])
  @@index([phase])
}

model Staff {
  id              String      @id @default(cuid())
  employeeId      String      @unique
  firstName       String
  lastName        String
  email           String      @unique
  role            StaffRole
  department      String
  specialization  String?
  yearsExperience Int         @default(0)
  isActive        Boolean     @default(true)
  hireDate        DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  assignedTasks        Task[]
  trialAssignments     TrialStaffAssignment[]
  ledTrials            ClinicalTrial[]         @relation("TrialLead")
  milestoneAssignments MilestoneAssignment[]

  @@index([role])
  @@index([isActive])
}

model TrialStaffAssignment {
  id          String    @id @default(cuid())
  trialId     String
  staffId     String
  role        StaffRole
  startDate   DateTime
  endDate     DateTime?
  effort      Float     @default(1.0)
  createdAt   DateTime  @default(now())

  trial       ClinicalTrial @relation(fields: [trialId], references: [id])
  staff       Staff         @relation(fields: [staffId], references: [id])

  @@unique([trialId, staffId])
  @@index([trialId])
  @@index([staffId])
}

model Project {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  description     String?
  status          ProjectStatus
  priority        TaskPriority
  plannedStart    DateTime
  plannedEnd      DateTime
  actualStart     DateTime?
  actualEnd       DateTime?
  budget          Decimal?      @db.Decimal(12, 2)
  percentComplete Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  trialId         String
  trial           ClinicalTrial @relation(fields: [trialId], references: [id])

  milestones      Milestone[]

  @@index([trialId])
  @@index([status])
}

model Milestone {
  id              String          @id @default(cuid())
  name            String
  description     String?
  status          MilestoneStatus
  dueDate         DateTime
  completedDate   DateTime?
  isCriticalPath  Boolean         @default(false)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  projectId       String
  project         Project         @relation(fields: [projectId], references: [id])

  tasks           Task[]
  assignments     MilestoneAssignment[]

  @@index([projectId])
  @@index([status])
}

model MilestoneAssignment {
  id          String    @id @default(cuid())
  milestoneId String
  staffId     String
  createdAt   DateTime  @default(now())

  milestone   Milestone @relation(fields: [milestoneId], references: [id])
  staff       Staff     @relation(fields: [staffId], references: [id])

  @@unique([milestoneId, staffId])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus
  priority       TaskPriority
  estimatedHours Float?
  actualHours    Float?
  dueDate        DateTime?
  completedAt    DateTime?
  tags           String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  milestoneId    String
  milestone      Milestone    @relation(fields: [milestoneId], references: [id])

  assigneeId     String?
  assignee       Staff?       @relation(fields: [assigneeId], references: [id])

  @@index([milestoneId])
  @@index([assigneeId])
  @@index([status])
}
